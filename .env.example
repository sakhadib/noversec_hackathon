# Frontend uses this base URL for Math Explainer API calls.
# Default uses Next.js local proxy path and works well for backend testing.
NEXT_PUBLIC_MATH_EXPLAINER_API_BASE_URL=/api/math-explainer

# Next.js server-side proxy target (backend local service).
# Backend team can run FastAPI on localhost:8000 and this works out of the box.
MATH_EXPLAINER_PROXY_TARGET=http://localhost:8000

# Optional: force mock video mode for frontend-only UI work.
# true => use mock adapter, false => use real adapter
NEXT_PUBLIC_FORCE_MOCK_VIDEO_API=false
